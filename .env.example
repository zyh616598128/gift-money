# 礼金管理系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# JWT 密钥（生产环境务必修改为强随机字符串）
GIFT_MONEY_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT 过期时间（小时）
GIFT_MONEY_JWT_EXPIRE_HOURS=24

# 数据库路径（默认在项目根目录）
GIFT_MONEY_DB_PATH=

# 服务器配置
GIFT_MONEY_HOST=0.0.0.0
GIFT_MONEY_PORT=8000

# CORS 允许的源（逗号分隔，留空表示允许所有）
GIFT_MONEY_CORS_ORIGINS=

# 日志级别: DEBUG / INFO / WARNING / ERROR / CRITICAL
GIFT_MONEY_LOG_LEVEL=INFO

# 数据备份路径（绝对路径，留空则禁用自动备份）
GIFT_MONEY_BACKUP_PATH=